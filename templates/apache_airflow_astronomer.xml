<?xml version="1.0"?>
<Container version="2">
  <Name>Astronomer</Name>
  <Repository>astrocrpublic.azurecr.io/runtime:3.2-4</Repository>
  <Registry>https://astrocrpublic.azurecr.io</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://www.astronomer.io/docs/astro/runtime-image-architecture</Support>
  <Project>https://airflow.apache.org/</Project>

  <Overview>Run Apache Airflow on Unraid using Astronomer Runtime. This template starts Airflow in standalone mode for single-node deployments and development/home-lab use.</Overview>

  <Category>Productivity: Tools:</Category>
  <WebUI>http://[IP]:[PORT:8080]</WebUI>
  <TemplateURL/>
  <Icon>https://airflow.apache.org/docs/apache-airflow/stable/_images/pin_large.png</Icon>
  <ExtraParams/>
  <PostArgs>bash -lc "airflow standalone"</PostArgs>
  <CPUset/>
  <DonateText/>
  <DonateLink/>
  <Requires/>

  <Config Name="Airflow Web UI" Target="8080" Default="" Mode="tcp" Description="Airflow webserver port" Type="Port" Display="always" Required="true" Mask="false">8080</Config>

  <Config Name="Airflow Home" Target="/usr/local/airflow" Default="" Mode="rw" Description="Persist AIRFLOW_HOME, including airflow.cfg, metadata DB, DAGs, logs, plugins, and config" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/astronomer</Config>

  <Config Name="Load Example DAGs" Target="AIRFLOW__CORE__LOAD_EXAMPLES" Default="False" Mode="" Description="Set to True to load Airflow example DAGs" Type="Variable" Display="always" Required="false" Mask="false">False</Config>
  <Config Name="Executor" Target="AIRFLOW__CORE__EXECUTOR" Default="LocalExecutor" Mode="" Description="Executor class for standalone deployments" Type="Variable" Display="always" Required="false" Mask="false">LocalExecutor</Config>
  <Config Name="Admin Username" Target="_AIRFLOW_WWW_USER_USERNAME" Default="admin" Mode="" Description="Airflow admin username" Type="Variable" Display="always" Required="false" Mask="false">admin</Config>
  <Config Name="Admin Password" Target="_AIRFLOW_WWW_USER_PASSWORD" Default="admin" Mode="" Description="Airflow admin password (change this)" Type="Variable" Display="always" Required="false" Mask="true">admin</Config>

  <TailscaleStateDir/>
</Container>
